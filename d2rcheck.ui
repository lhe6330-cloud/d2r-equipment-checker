<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1400</width>
    <height>850</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>D2R Equipment Checker</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* ===== MAIN WINDOW ===== */
QMainWindow, QWidget#centralwidget {
    background-color: #12141a;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 12px;
    color: #c8ccd4;
}

/* ===== GROUP BOXES ===== */
QGroupBox {
    background-color: #1a1d24;
    border: 1px solid #2a2f3a;
    border-radius: 6px;
    margin-top: 14px;
    padding: 12px;
    padding-top: 20px;
    font-weight: 600;
    font-size: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 2px 10px;
    background-color: #1a1d24;
    color: #5dadec;
    font-size: 13px;
}

/* ===== BUTTONS ===== */
QPushButton {
    background-color: #252a34;
    border: 1px solid #3a3f4a;
    border-radius: 4px;
    padding: 8px 16px;
    color: #c8ccd4;
    font-weight: 500;
    min-height: 24px;
}

QPushButton:hover {
    background-color: #2f3542;
    border-color: #5dadec;
}

QPushButton:pressed {
    background-color: #1a1d24;
}

QPushButton:disabled {
    background-color: #1a1d24;
    border-color: #252a34;
    color: #4a4f5a;
}

/* Primary Action Button */
QPushButton#start_button {
    background-color: #2d8a4e;
    border-color: #3da864;
    color: #ffffff;
    font-weight: 600;
}

QPushButton#start_button:hover {
    background-color: #3da864;
}

/* Danger Buttons */
QPushButton#stop_button, QPushButton#stop_list_check {
    background-color: #8a2d3d;
    border-color: #a83d4e;
    color: #ffffff;
}

QPushButton#stop_button:hover, QPushButton#stop_list_check:hover {
    background-color: #a83d4e;
}

/* Export Button */
QPushButton#export_orderlist {
    background-color: #2d5a8a;
    border-color: #3d7ab0;
    color: #ffffff;
}

QPushButton#export_orderlist:hover {
    background-color: #3d7ab0;
}

/* ===== INPUT FIELDS ===== */
QLineEdit {
    background-color: #1e222a;
    border: 1px solid #2a2f3a;
    border-radius: 4px;
    padding: 8px 12px;
    color: #c8ccd4;
    selection-background-color: #5dadec;
}

QLineEdit:focus {
    border-color: #5dadec;
}

QLineEdit::placeholder {
    color: #5a5f6a;
}

/* ===== COMBO BOX ===== */
QComboBox {
    background-color: #1e222a;
    border: 1px solid #2a2f3a;
    border-radius: 4px;
    padding: 8px 12px;
    color: #c8ccd4;
    min-width: 140px;
}

QComboBox:hover, QComboBox:focus {
    border-color: #5dadec;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
    padding-right: 8px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #5dadec;
}

QComboBox QAbstractItemView {
    background-color: #1e222a;
    border: 1px solid #5dadec;
    selection-background-color: #2d5a8a;
    color: #c8ccd4;
    padding: 4px;
}

/* ===== CHECK BOXES ===== */
QCheckBox {
    spacing: 8px;
    color: #c8ccd4;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 2px solid #3a3f4a;
    background-color: #1e222a;
}

QCheckBox::indicator:hover {
    border-color: #5dadec;
}

QCheckBox::indicator:checked {
    background-color: #5dadec;
    border-color: #5dadec;
}

/* ===== TABLES ===== */
QTableWidget {
    background-color: #1e222a;
    alternate-background-color: #22262e;
    border: 1px solid #2a2f3a;
    border-radius: 4px;
    gridline-color: #2a2f3a;
    selection-background-color: #2d5a8a;
    selection-color: #ffffff;
}

QTableWidget::item {
    padding: 6px 8px;
    border: none;
}

QTableWidget::item:selected {
    background-color: #2d5a8a;
}

QHeaderView::section {
    background-color: #252a34;
    color: #8a9bae;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    padding: 8px 10px;
    border: none;
    border-bottom: 2px solid #2a2f3a;
    border-right: 1px solid #2a2f3a;
}

QHeaderView::section:last {
    border-right: none;
}

/* ===== SCROLL BARS ===== */
QScrollBar:vertical {
    background-color: #1a1d24;
    width: 10px;
    margin: 0;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background-color: #3a3f4a;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #5dadec;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    height: 0;
    background: none;
}

QScrollBar:horizontal {
    background-color: #1a1d24;
    height: 10px;
    margin: 0;
    border-radius: 5px;
}

QScrollBar::handle:horizontal {
    background-color: #3a3f4a;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #5dadec;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    width: 0;
    background: none;
}

/* ===== STATUS BAR ===== */
QStatusBar {
    background-color: #1a1d24;
    color: #6a7a8a;
    border-top: 1px solid #2a2f3a;
    padding: 6px 12px;
    font-size: 11px;
}

/* ===== LABELS ===== */
QLabel {
    color: #8a9bae;
    font-size: 12px;
}

QLabel[headerLabel="true"] {
    color: #5dadec;
    font-size: 11px;
    font-weight: 600;
}
